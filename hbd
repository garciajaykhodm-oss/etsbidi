<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Happy Birthday, My Bebu 💖</title>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&family=Dancing+Script:wght@600&display=swap');

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #1a1a1a, #2d2d2d, #404040);
            background-size: 400% 400%;
            animation: gradientShift 12s ease infinite;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #333;
            overflow: hidden;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Screens */
        .welcome-screen { text-align: center; color: white; }
        .welcome-title { font-size: 2.5rem; margin-bottom: 2rem; }
        .welcome-btn {
            padding: 1rem 2rem;
            font-size: 1.1rem;
            border-radius: 50px;
            border: none;
            background: #fff;
            color: #333;
            cursor: pointer;
            font-weight: 600;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .main-container {
            display: none;
            width: 90%;
            max-width: 500px;
            max-height: 85vh;
            background: #fff; /* Paper background */
            background-image: radial-gradient(#efefef 1px, transparent 0);
            background-size: 20px 20px;
            padding: 30px;
            border-radius: 5px; /* Sharper edges like a real letter */
            box-shadow: 10px 10px 0px rgba(0,0,0,0.2), 0 10px 30px rgba(0,0,0,0.5);
            text-align: center;
            overflow-y: auto; 
            position: relative;
            border: 1px solid #ddd;
        }

        h1 { font-family: 'Dancing Script', cursive; color: #d63384; margin-bottom: 15px; font-size: 2.2rem; }

        .message {
            text-align: left;
            line-height: 1.8;
            font-size: 1.05rem;
            white-space: pre-line;
            margin-bottom: 20px;
            color: #444;
        }

        .countdown {
            background: #fff5f8;
            padding: 15px;
            border: 1px dashed #d63384;
            border-radius: 10px;
            font-weight: 600;
            color: #d63384;
            margin-top: 10px;
        }

        .music-btn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: white;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            z-index: 100;
            font-size: 1.5rem;
        }

        /* Fireworks animation */
        @keyframes firework {
            0% { transform: translateY(0) scale(0); opacity: 1; }
            100% { transform: translateY(-500px) scale(1.5); opacity: 0; }
        }

        /* Custom Scrollbar for the paper look */
        .main-container::-webkit-scrollbar { width: 6px; }
        .main-container::-webkit-scrollbar-track { background: #f1f1f1; }
        .main-container::-webkit-scrollbar-thumb { background: #d63384; border-radius: 10px; }
    </style>
</head>

<body>

<div class="welcome-screen" id="welcomeScreen">
    <div class="welcome-title">happy birthday, my bebu 💖</div>
    <button class="welcome-btn" onclick="startExperience()">click pls 😭</button>
</div>

<div class="main-container" id="mainContainer">
    <h1>Happy 21st Birthday, Matty 🎂</h1>
    <div class="message" id="message"></div>
    <div class="countdown" id="countdown"></div>
</div>

<div class="music-btn" id="musicToggle" onclick="toggleMusic()">🎵</div>

<audio id="bgMusic" loop>
    <source src="Libu-libong buwan (Lyrics) - Kyle Raphael (1).mp3" type="audio/mpeg">
</audio>

<script>
const bgMusic = document.getElementById("bgMusic");
let isPlaying = false;

const fullMessage = `matty, my love;

happy birthday, mahal ko.

i don’t even know where to start, because no words ever feel enough when it comes to you.

if i could gather every soft and gentle word in the world, 
i would stitch them together just to make something that could match how much you mean to me.

you came into my life so quietly, 
but somehow you became everything i didn’t even know i needed.

you became my peace in the middle of chaos, my comfort on days i don’t feel okay, 
and the person i always run to without even thinking.

i love the way you care, 
the way you try even when things are hard, 
the way you stay, even when it’s not easy.

you make me feel safe in ways i can’t explain, 
like i can just be myself without fear, 
and that alone means everything to me.

so today, 
i just want you to feel even a small piece of the love you give to everyone around you, 
especially to me.

because you deserve a love that stays, 
a love that understands.

and i hope you know… i’m here.

through everything, in all the ways that i can be.

i’ll stay loving you, today and in all the days after.

happy birthday, my bebu ♡

i love you more than words can ever hold.`;

function startExperience() {
    document.getElementById("welcomeScreen").style.display = "none";
    document.getElementById("mainContainer").style.display = "block";
    
    // Set message instantly
    document.getElementById("message").innerText = fullMessage;

    // Start Music
    bgMusic.play().then(() => {
        isPlaying = true;
        document.getElementById("musicToggle").innerText = "⏸️";
    }).catch(e => console.log("Interaction required for audio"));

    setInterval(updateCountdown, 1000);
}

function launchFireworks() {
    const spark = document.createElement("div");
    spark.style.position = "fixed";
    spark.style.left = Math.random() * 100 + "%";
    spark.style.bottom = "0";
    spark.style.width = "8px";
    spark.style.height = "8px";
    spark.style.background = `hsl(${Math.random() * 360}, 100%, 70%)`;
    spark.style.borderRadius = "50%";
    spark.style.boxShadow = "0 0 10px white";
    spark.style.animation = "firework 2s ease-out forwards";
    document.body.appendChild(spark);
    setTimeout(() => spark.remove(), 2000);
}

function toggleMusic() {
    if (isPlaying) {
        bgMusic.pause();
        document.getElementById("musicToggle").innerText = "▶️";
    } else {
        bgMusic.play();
        document.getElementById("musicToggle").innerText = "⏸️";
    }
    isPlaying = !isPlaying;
}

function updateCountdown() {
    const now = new Date();
    const start = new Date(2025, 3, 7, 0, 0, 0); 
    const end = new Date(2025, 3, 8, 0, 0, 0);

    if (now >= start && now < end) {
        document.getElementById("countdown").innerHTML = "<h2>HAPPY BIRTHDAY BEBU 🎉💖</h2>";
        launchFireworks();
        return;
    }

    const dist = start - now;
    if (dist < 0) {
        document.getElementById("countdown").innerHTML = "Enjoy your special day, Matty! ✨";
        return;
    }

    const d = Math.floor(dist / (1000 * 60 * 60 * 24));
    const h = Math.floor((dist % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const m = Math.floor((dist % (1000 * 60 * 60)) / (1000 * 60));
    const s = Math.floor((dist % (1000 * 60)) / 1000);

    document.getElementById("countdown").innerHTML = `${d}d ${h}h ${m}m ${s}s until your day!`;
}
</script>

</body>
</html>
