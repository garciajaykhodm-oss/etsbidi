<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday, My Bebu 💖</title>

<style>
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');

*{margin:0;padding:0;box-sizing:border-box;}

body{
    font-family:'Poppins',sans-serif;
    background:linear-gradient(135deg,#1a1a1a,#2d2d2d,#404040,#5a5a5a);
    background-size:400% 400%;
    animation:gradientShift 12s ease infinite;
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    color:white;
    overflow:hidden;
}

@keyframes gradientShift{
    0%{background-position:0% 50%;}
    50%{background-position:100% 50%;}
    100%{background-position:0% 50%;}
}

.welcome-screen{text-align:center;animation:pulse 2s infinite;}
.welcome-title{font-size:3rem;margin-bottom:2rem;}

.welcome-btn{
    padding:1rem 2rem;
    font-size:1.2rem;
    border-radius:50px;
    border:none;
    background:#444;
    color:white;
    cursor:pointer;
}

@keyframes pulse{
    0%{transform:scale(1);}
    50%{transform:scale(1.05);}
    100%{transform:scale(1);}
}

.main-container{
    display:none;
    text-align:center;
    max-width:700px;
    padding:20px;
}

.message{
    margin-top:20px;
    line-height:1.7;
    font-size:1.1rem;
    min-height:220px;
}

.countdown{margin-top:20px;font-size:1.2rem;}

.music-btn{
    position:fixed;
    bottom:20px;
    right:20px;
    background:#333;
    padding:10px 15px;
    border-radius:50px;
    cursor:pointer;
}

/* 🎆 fireworks */
@keyframes firework{
    0%{transform:translateY(0) scale(0);opacity:1;}
    100%{transform:translateY(-300px) scale(1.5);opacity:0;}
}
</style>
</head>

<body>

<div class="welcome-screen" id="welcomeScreen">
    <div class="welcome-title">happy birthday, my bebu 💖</div>
    <button class="welcome-btn" onclick="startExperience()">click pls 😭</button>
</div>

<div class="main-container" id="mainContainer">
    <h1>Happy 21st Birthday, Matty 🎂✨</h1>
    <div class="message" id="message"></div>
    <div class="countdown" id="countdown"></div>
</div>

<div class="music-btn" onclick="toggleMusic()">🎵</div>

<audio id="bgMusic" loop preload="auto">
    <source src="music.mp3" type="audio/mpeg">
</audio>

<script>
const bgMusic = document.getElementById("bgMusic");
let isPlaying = false;

/* 💖 MESSAGE */
const fullMessage = `matty, my love...

happy birthday, mahal ko.

i don’t even know where to start, because no words ever feel enough when it comes to you.

if i could gather every soft and gentle word in the world,
i would stitch them together just to make something that could match how much you mean to me.

you came into my life so quietly,
but somehow you became everything i didn’t even know i needed.

you became my peace in the middle of chaos,
my comfort on days i don’t feel okay,
and the person i always run to without even thinking.

i love the way you care,
the way you try even when things are hard,
the way you stay, even when it’s not easy.

you make me feel safe in ways i can’t explain,
like i can just be myself without fear,
and that alone means everything to me.

on your birthday,
i just want you to feel even a small piece of the love you give to everyone around you,
especially to me.

because you deserve a love that stays,
a love that understands,
a love that never gives up on you.

and i hope you know…
i’m here.

through everything,
in all the ways that i can be.

i’ll stay loving you,
today and in all the days after.

happy birthday, my bebu ♡

i love you more than words can ever hold.`;

/* ✍️ typing */
function typeMessage(text, element){
    let i = 0;
    function typing(){
        if(i < text.length){
            element.innerHTML += text.charAt(i) === "\n" ? "<br>" : text.charAt(i);
            i++;
            setTimeout(typing, 25);
        }
    }
    typing();
}

/* 🎆 fireworks */
function launchFireworks(){
    for(let i=0;i<40;i++){
        const spark=document.createElement("div");
        spark.style.position="fixed";
        spark.style.left=Math.random()*100+"%";
        spark.style.bottom="0";
        spark.style.width="6px";
        spark.style.height="6px";
        spark.style.background=`hsl(${Math.random()*360},100%,70%)`;
        spark.style.borderRadius="50%";
        spark.style.animation="firework 1.5s ease-out forwards";
        document.body.appendChild(spark);
        setTimeout(()=>spark.remove(),1500);
    }
}

/* ▶️ START (FIXED MUSIC) */
function startExperience(){
    const music = document.getElementById("bgMusic");

    music.currentTime = 0;
    music.muted = false;

    const playPromise = music.play();

    if (playPromise !== undefined) {
        playPromise.then(() => {
            isPlaying = true;
        }).catch(() => {
            document.body.addEventListener("click", () => {
                music.play();
            }, { once: true });
        });
    }

    document.getElementById("welcomeScreen").style.display="none";
    document.getElementById("mainContainer").style.display="block";

    typeMessage(fullMessage, document.getElementById("message"));
    setInterval(updateCountdown,1000);
}

/* 🎵 toggle */
function toggleMusic(){
    if(isPlaying){
        bgMusic.pause();
    }else{
        bgMusic.play();
    }
    isPlaying=!isPlaying;
}

/* ⏳ countdown */
function updateCountdown(){
    const now=new Date();
    const start=new Date(2026,3,7,0,0,0);
    const end=new Date(2026,3,8,0,0,0);

    if(now>=start && now<end){
        document.getElementById("countdown").innerHTML=
        "<h2>HAPPY BIRTHDAY BEBU 🎉💖</h2>";
        launchFireworks();
        return;
    }

    const dist=start-now;

    const d=Math.floor(dist/(1000*60*60*24));
    const h=Math.floor((dist%(1000*60*60*24))/(1000*60*60));
    const m=Math.floor((dist%(1000*60*60))/(1000*60));
    const s=Math.floor((dist%(1000*60))/1000);

    document.getElementById("countdown").innerHTML=
    d+" days "+h+" hrs "+m+" min "+s+" sec";
}
</script>

</body>
</html>
