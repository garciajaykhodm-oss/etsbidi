<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday, My Bebu 💖</title>

<style>
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, #1a1a1a, #2d2d2d, #404040, #5a5a5a);
    background-size: 400% 400%;
    animation: gradientShift 12s ease infinite;
    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    color: white;
    overflow: hidden;
}

@keyframes gradientShift {
    0% {background-position: 0% 50%;}
    50% {background-position: 100% 50%;}
    100% {background-position: 0% 50%;}
}

.welcome-screen {
    text-align: center;
    animation: pulse 2s infinite;
}

.welcome-title {
    font-size: 3rem;
    margin-bottom: 2rem;
}

.welcome-btn {
    padding: 1rem 2rem;
    font-size: 1.2rem;
    border-radius: 50px;
    border: none;
    background: #444;
    color: white;
    cursor: pointer;
    transition: 0.3s;
}

.welcome-btn:hover {
    background: #666;
    transform: scale(1.05);
}

@keyframes pulse {
    0% {transform: scale(1);}
    50% {transform: scale(1.05);}
    100% {transform: scale(1);}
}

.main-container {
    display: none;
    text-align: center;
    max-width: 700px;
    padding: 20px;
}

.message {
    margin-top: 20px;
    line-height: 1.6;
    font-size: 1.1rem;
}

.hearts {
    font-size: 2rem;
    margin: 10px 0;
}

.countdown {
    margin-top: 20px;
    font-size: 1.2rem;
}

.music-btn {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #333;
    padding: 10px 15px;
    border-radius: 50px;
    cursor: pointer;
}

/* 💖 floating hearts animation */
@keyframes floatUp {
    0% {
        transform: translateY(0);
        opacity: 1;
    }
    100% {
        transform: translateY(-100vh);
        opacity: 0;
    }
}
</style>
</head>

<body>

<div class="welcome-screen" id="welcomeScreen">
    <div class="welcome-title">happy birthday, my bebu 💖</div>
    <button class="welcome-btn" onclick="revealSurprise()">click pls 😭</button>
</div>

<div class="main-container" id="mainContainer">
    <h1>Happy 21st Birthday, Matty 🎂✨</h1>
    <div class="hearts">💖💖💖</div>

    <div class="message">
        matty, my love 🥺 <br><br>

        happy birthday, mahal ko.<br><br>

        if i could gather all the softest words,<br>
        i'd stitch them into a sky just for you—<br>
        so every time you look up,<br>
        you'd remember how deeply you are loved.<br><br>

        you became my peace,<br>
        my safe place,<br>
        my favorite person.<br><br>

        i love you so much, always ♡
    </div>

    <div class="countdown" id="countdown"></div>
</div>

<div class="music-btn" onclick="toggleMusic()">🎵</div>

<audio id="bgMusic" loop>
    <source src="music.mp3" type="audio/mpeg">
</audio>

<script>
const bgMusic = document.getElementById("bgMusic");
let isPlaying = false;

function revealSurprise() {
    document.getElementById("welcomeScreen").style.display = "none";
    document.getElementById("mainContainer").style.display = "block";

    bgMusic.play().catch(()=>{});
    isPlaying = true;

    setInterval(updateCountdown, 1000);
}

function toggleMusic() {
    if(isPlaying){
        bgMusic.pause();
    } else {
        bgMusic.play();
    }
    isPlaying = !isPlaying;
}

function updateCountdown() {
    const now = new Date();

    const birthdayStart = new Date(2026, 3, 7, 0, 0, 0);
    const nextDay = new Date(2026, 3, 8, 0, 0, 0);

    // 🎉 EXACT MIDNIGHT TRIGGER
    if (now >= birthdayStart && now < nextDay) {
        document.getElementById("countdown").innerHTML =
            "<h2>HAPPY BIRTHDAY BEBU 🎉💖</h2>";

        launchHearts();
        return;
    }

    const distance = birthdayStart - now;

    const d = Math.floor(distance / (1000*60*60*24));
    const h = Math.floor((distance%(1000*60*60*24))/(1000*60*60));
    const m = Math.floor((distance%(1000*60*60))/(1000*60));
    const s = Math.floor((distance%(1000*60))/1000);

    document.getElementById("countdown").innerHTML =
        d+" days "+h+" hrs "+m+" min "+s+" sec";
}

function launchHearts() {
    for(let i = 0; i < 30; i++) {
        const heart = document.createElement("div");
        heart.innerHTML = "💖";

        heart.style.position = "fixed";
        heart.style.left = Math.random() * 100 + "%";
        heart.style.bottom = "0";
        heart.style.fontSize = (Math.random() * 20 + 20) + "px";
        heart.style.animation = "floatUp 3s linear forwards";

        document.body.appendChild(heart);

        setTimeout(() => heart.remove(), 3000);
    }
}
</script>

</body>
</html>
